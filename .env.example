# Docker Compose environment variables
# Copy this file to .env and fill in local secrets. Do not commit real secrets.

# PostgreSQL
POSTGRES_DB=aiwiki
POSTGRES_USER=aiwiki
POSTGRES_PASSWORD=aiwiki123
POSTGRES_PORT=5433
DATABASE_URL=postgresql://aiwiki:aiwiki123@db:5432/aiwiki

# LLM provider
LLM_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=mimo-v2.5-pro

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
